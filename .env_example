# ==============================================================================
# FastAPI Server Settings
# ==============================================================================
# HOST: The network address where the Uvicorn ASGI server binds to.
#       Use '127.0.0.1' for local dev, or '0.0.0.0' to bind to all interfaces (e.g., Docker).
HOST=

# PORT: The port number the server will listen on.
PORT=

# RELOAD: Enable or disable auto-reloading upon source code modifications.
#         Set to 'True' for active local development; MUST be 'False' in production.
RELOAD=


# ==============================================================================
# SQLAlchemy Database Engine Settings (Async)
# ==============================================================================
# DATABASE_URL: The asynchronous database connection string.
#               - Dev (SQLite Async): sqlite+aiosqlite:///./dbname.db
#               - Production (PostgreSQL Async): postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=

# ECHO: Enable or disable SQLAlchemy engine SQL statement logging to stdout.
#       Set to 'True' to inspect generated SQL queries; set to 'False' in production.
ECHO=


# ==============================================================================
# SQLAlchemy Async Session Settings
# ==============================================================================
# AUTO_FLUSH: Controls whether the session automatically flushes changes to the database
#             before executing any query. Set to 'False' to prevent premature flushes.
AUTO_FLUSH=

# EXPIRE_ON_COMMIT: If 'True', all instances are marked expired after session commit,
#                   forcing a reload from the database on subsequent access.
#                   Set to 'False' in async environments to avoid accidental lazy-loading errors.
EXPIRE_ON_COMMIT=


# ==============================================================================
# JWT Authentication Settings
# ==============================================================================
# SECRET_KEY: A secure, private key string used to sign JWT tokens.
#             Keep this highly confidential in production (e.g., generate a 32-byte hex key).
SECRET_KEY=secret-key-in-production-time-in-this-place

# ALGORITHM: The encryption algorithm used to encode/decode the JWT signature. 
ALGORITHM=

# ACCESS_TOKEN_EXPIRE_MINUTES: JWT access token lifespan in minutes. 
ACCESS_TOKEN_EXPIRE_MINUTES=